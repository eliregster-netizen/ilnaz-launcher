{
  "name": "ilnaz-gaming-launcher",
  "version": "0.1.0",
  "description": "ILNAZ GAMING LAUNCHER - A Steam-like launcher for Arch Linux",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "dev:full": "concurrently \"vite\" \"electron .\" \"node server/index.js\"",
    "build": "vite build",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "start": "electron .",
    "admin": "node server/admin.js",
    "server": "node server/index.js",
    "electron:build": "electron-builder"
  },
  "keywords": ["gaming", "launcher", "steam", "linux"],
  "author": "ILNAZ GAMING",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.11",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.2",
    "fs-extra": "^11.2.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "socket.io-client": "^4.7.4"
  },
  "build": {
    "appId": "com.ilnazgaming.launcher",
    "productName": "ILNAZ Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
